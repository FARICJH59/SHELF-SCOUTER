# Google AI / Gemma 4 API key
# Get your key at https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# Model to use (default: gemma-4-e4b-it for fastest vision inference)
# Options: gemma-4-e2b-it, gemma-4-e4b-it, gemma-4-26b-a4b-it, gemma-4-31b-it
GEMMA_MODEL=gemma-4-e4b-it

# Flask server settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
